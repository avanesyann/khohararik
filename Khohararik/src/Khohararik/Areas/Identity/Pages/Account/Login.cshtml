@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="d-flex justify-content-center align-items-start py-4">
    <div class="card border-0 shadow" style="width:100%;max-width:440px;border-radius:1rem;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div style="font-size:2.5rem;">🥘</div>
                <h2 class="fw-bold mt-2" style="color:#2d6a4f;">@L["Auth_WelcomeBack"]</h2>
                <p class="text-muted small">@L["Auth_SignIn"]</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">@L["Auth_Email"]</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="" />
                    <label asp-for="Input.Password">@L["Auth_Password"]</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">@L["Auth_RememberMe"]</label>
                </div>
                <button id="login-submit" type="submit" class="w-100 btn btn-lg fw-semibold text-white" style="background:#2d6a4f;border-color:#2d6a4f;">
                    <i class="bi bi-box-arrow-in-right me-1"></i> @L["Auth_LogIn"]
                </button>
            </form>

            <hr class="my-4" />
            <div class="text-center small">
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color:#2d6a4f;">@L["Auth_CreateAccount"]</a>
                &nbsp;·&nbsp;
                <a asp-page="./ForgotPassword" style="color:#2d6a4f;">@L["Auth_ForgotPassword"]</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
