@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="d-flex justify-content-center align-items-start py-4">
    <div class="card border-0 shadow" style="width:100%;max-width:440px;border-radius:1rem;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div style="font-size:2.5rem;">🥘</div>
                <h2 class="fw-bold mt-2" style="color:#2d6a4f;">@L["Auth_CreateTitle"]</h2>
                <p class="text-muted small">@L["Auth_CreateSub"]</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">@L["Auth_Email"]</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                    <label asp-for="Input.Password">@L["Auth_Password"]</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                    <label asp-for="Input.ConfirmPassword">@L["Auth_ConfirmPassword"]</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg fw-semibold text-white" style="background:#2d6a4f;border-color:#2d6a4f;">
                    <i class="bi bi-person-plus me-1"></i> @L["Auth_CreateTitle"]
                </button>
            </form>

            <hr class="my-4" />
            <div class="text-center small">
                @L["Auth_AlreadyHave"]
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" style="color:#2d6a4f;">@L["Auth_LogIn"]</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
