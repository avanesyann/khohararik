@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
}

<h2 class="fw-bold mb-4">Dashboard</h2>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="display-3 mb-2">🏷️</div>
            <h5>Categories</h5>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="display-3 mb-2">🧅</div>
            <h5>Ingredients</h5>
            <a asp-controller="Ingredients" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="display-3 mb-2">📖</div>
            <h5>Recipes</h5>
            <a asp-controller="Recipes" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
        </div>
    </div>
</div>
