@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Recipe";
}
@model Khohararik.Models.Recipe
@{
    var allIngredients = ViewBag.Ingredients as List<Khohararik.Models.Ingredient> ?? new();
}

<div class="card border-0 shadow-sm p-4">
    <h4 class="fw-bold mb-4">New Recipe</h4>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="TotalCalories" class="form-label fw-semibold">Total Calories (kcal)</label>
                <input asp-for="TotalCalories" class="form-control" type="number" step="0.1" />
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-semibold"></label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Instructions" class="form-label fw-semibold">Instructions <small class="text-muted">(one step per line)</small></label>
            <textarea asp-for="Instructions" class="form-control" rows="6"></textarea>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="PrepTimeMinutes" class="form-label fw-semibold">Prep Time (min)</label>
                <input asp-for="PrepTimeMinutes" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label asp-for="CookTimeMinutes" class="form-label fw-semibold">Cook Time (min)</label>
                <input asp-for="CookTimeMinutes" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label asp-for="Servings" class="form-label fw-semibold">Servings</label>
                <input asp-for="Servings" class="form-control" type="number" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Recipe Image</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>

        <h5 class="fw-bold mb-3">Ingredients</h5>
        <div class="mb-2">
            <input type="text" id="ingredientSearch" class="form-control form-control-sm" placeholder="Search ingredients..." />
        </div>
        <div class="card border bg-light p-3 mb-4" style="max-height: 400px; overflow-y: auto;" id="ingredientList">
            @foreach (var ing in allIngredients)
            {
                <div class="row g-2 align-items-center mb-2 ingredient-row" data-name="@ing.Name.ToLower() @ing.Category.Name.ToLower()">
                    <div class="col-auto">
                        <input type="checkbox" name="selectedIngredients" value="@ing.Id"
                               id="ing-@ing.Id" class="form-check-input ingredient-check" />
                    </div>
                    <div class="col">
                        <label for="ing-@ing.Id" class="form-check-label">
                            @ing.Name <small class="text-muted">(@ing.Category.Name)</small>
                        </label>
                    </div>
                    <div class="col-auto">
                        <div class="input-group input-group-sm" style="width: 120px;">
                            <input type="number" name="w_@ing.Id" value="100" min="1" step="0.1"
                                   class="form-control ingredient-weight" id="weight-@ing.Id"
                                   disabled />
                            <span class="input-group-text">g</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Save Recipe</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Live ingredient search
    document.getElementById('ingredientSearch').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#ingredientList .ingredient-row').forEach(row => {
            row.style.display = row.dataset.name.includes(q) ? '' : 'none';
        });
    });

    // Enable weight inputs only when checkbox is checked
    document.querySelectorAll('.ingredient-check').forEach(cb => {
        cb.addEventListener('change', function() {
            const id = this.value;
            const weightInput = document.getElementById('weight-' + id);
            weightInput.disabled = !this.checked;
            if (!this.checked) weightInput.value = 100;
        });
    });
</script>
}
