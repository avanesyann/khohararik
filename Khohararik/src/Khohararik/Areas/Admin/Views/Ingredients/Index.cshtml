@{
    Layout = "_Layout";
    ViewData["Title"] = "Ingredients";
}
@model List<Khohararik.Models.Ingredient>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Ingredients</h3>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i>New Ingredient</a>
</div>

<div class="card border-0 shadow-sm">
    <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Calories/100g</th>
                <th>Default Weight (g)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ing in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(ing.ImageUrl))
                        {
                            <img src="@ing.ImageUrl" style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
                        }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td class="fw-semibold">@ing.Name</td>
                    <td><span class="badge bg-secondary">@ing.Category.Name</span></td>
                    <td>@ing.CaloriesPer100g</td>
                    <td>@ing.DefaultWeight g</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@ing.Id" class="btn btn-sm btn-outline-primary me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@ing.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this ingredient?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
