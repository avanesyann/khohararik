<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Khohararik</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: #f1f3f5; }
        .sidebar { min-height: 100vh; background: #212529; }
        .sidebar .nav-link { color: #adb5bd; padding: .6rem 1rem; border-radius: 6px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,.1); color: #fff; }
        .sidebar .nav-link i { width: 20px; }
        .brand { font-weight: 700; color: #52b788; font-size: 1.2rem; }
        .main-content { min-height: 100vh; }
        .topbar { background: #fff; border-bottom: 1px solid #dee2e6; padding: .75rem 1.5rem; }
    </style>
</head>
<body>
<div class="d-flex">
    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-3" style="width: 240px; position: fixed; top: 0; bottom: 0; overflow-y: auto;">
        <a href="/Admin" class="brand d-block mb-4 text-decoration-none">
            🥘 Khohararik <small class="text-muted d-block" style="font-size:.7rem;font-weight:400;">Admin Panel</small>
        </a>
        <nav class="flex-column nav gap-1">
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="nav-link">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="nav-link">
                <i class="bi bi-tags me-2"></i>Categories
            </a>
            <a asp-area="Admin" asp-controller="Ingredients" asp-action="Index" class="nav-link">
                <i class="bi bi-basket me-2"></i>Ingredients
            </a>
            <a asp-area="Admin" asp-controller="Recipes" asp-action="Index" class="nav-link">
                <i class="bi bi-journal-richtext me-2"></i>Recipes
            </a>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link">
                <i class="bi bi-people me-2"></i>Users
            </a>
            <hr class="border-secondary" />
            <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link">
                <i class="bi bi-box-arrow-left me-2"></i>Back to Site
            </a>
        </nav>
    </div>

    <!-- Main -->
    <div class="main-content flex-grow-1" style="margin-left: 240px;">
        <div class="topbar d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold text-muted">@ViewData["Title"]</h6>
            <partial name="_LoginPartial" />
        </div>

        <div class="p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
