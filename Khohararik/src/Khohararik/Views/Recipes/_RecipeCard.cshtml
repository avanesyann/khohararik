@model Khohararik.ViewModels.RecipeRecommendationViewModel
@{
    var badgeClass = Model.IsFullMatch ? "bg-success" : "bg-warning text-dark";
    var badgeText = Model.IsFullMatch ? L["Rec_PerfectMatch"].Value : $"{Model.MatchPercent}% Match";
}
<div class="card recipe-card shadow-sm h-100">
    @if (!string.IsNullOrEmpty(Model.Recipe.ImageUrl))
    {
        <img src="@Model.Recipe.ImageUrl" alt="@Model.Recipe.Name" class="card-img-top" />
    }
    else
    {
        <div class="d-flex align-items-center justify-content-center bg-light" style="height:200px;font-size:4rem;">🍽️</div>
    }
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title fw-bold mb-0">@Model.Recipe.Name</h6>
            <span class="badge @badgeClass ms-2 text-nowrap">@badgeText</span>
        </div>

        <!-- Match progress bar -->
        <div class="mb-2">
            <div class="progress" style="height: 6px;">
                <div class="progress-bar @(Model.IsFullMatch ? "bg-success" : "bg-warning")"
                     style="width: @Model.MatchPercent%"></div>
            </div>
            <small class="text-muted">@Model.MatchedCount / @Model.TotalRequired @L["Rec_Matched"]</small>
        </div>

        @if (Model.Recipe.TotalCalories > 0)
        {
            <small class="text-muted mb-2"><i class="bi bi-fire me-1"></i>@Model.Recipe.TotalCalories kcal</small>
        }

        @if (Model.MissingIngredients.Any())
        {
            <small class="text-danger mb-2">
                <i class="bi bi-x-circle me-1"></i>@L["Rec_Missing"] @string.Join(", ", Model.MissingIngredients.Take(3))
                @if (Model.MissingIngredients.Count > 3) { <span>+@(Model.MissingIngredients.Count - 3) @L["Rec_More"]</span> }
            </small>
        }

        <a asp-controller="Recipes" asp-action="Details" asp-route-id="@Model.Recipe.Id"
           class="btn btn-sm btn-outline-success mt-auto">
            <i class="bi bi-book-open me-1"></i>@L["Rec_ViewRecipe"]
        </a>
    </div>
</div>
