<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khohararik</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary: #2d6a4f;
            --primary-light: #52b788;
            --accent: #f77f00;
        }
        body { background: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar-brand { font-weight: 700; color: var(--primary) !important; font-size: 1.4rem; }
        .navbar { background: #fff !important; border-bottom: 2px solid var(--primary-light); }
        .nav-link:hover { color: var(--primary) !important; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-light); border-color: var(--primary-light); }
        .cart-badge { position: relative; }
        .cart-badge .badge { position: absolute; top: -6px; right: -10px; font-size: 0.65rem; }
        footer { background: var(--primary); color: #fff; padding: 1.5rem 0; margin-top: auto; }
        footer a { color: var(--primary-light); }
        .ingredient-card { transition: transform .2s, box-shadow .2s; border: none; }
        .ingredient-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.12); }
        .ingredient-card img { height: 160px; object-fit: cover; }
        .recipe-card { transition: transform .2s, box-shadow .2s; border: none; }
        .recipe-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.12); }
        .recipe-card img { height: 200px; object-fit: cover; }
        .match-badge-full { background: #2d6a4f; }
        .match-badge-partial { background: var(--accent); }
        .category-pill { cursor: pointer; }
        .category-pill.active { background: var(--primary) !important; color: #fff !important; border-color: var(--primary) !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🥘 Khohararik
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Ingredients" asp-action="Index">
                                <i class="bi bi-grid"></i> @L["Nav_Ingredients"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Recipes" asp-action="Index">
                                <i class="bi bi-journal-richtext"></i> @L["Nav_Recipes"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-success" asp-area="" asp-controller="Recipes" asp-action="Recommendations">
                                <i class="bi bi-stars"></i> @L["Nav_GetRecommendations"]
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-gear"></i> @L["Nav_Admin"]
                                </a>
                            </li>
                        }
                    </ul>
                                        <div class="d-flex align-items-center gap-2">
                        <a asp-area="" asp-controller="Cart" asp-action="Index" class="btn btn-outline-success cart-badge position-relative">
                            <i class="bi bi-cart3"></i>
                            <span class="badge bg-danger" id="cart-count">0</span>
                        </a>
                        <partial name="_LoginPartial" />
                        <div class="d-flex gap-1 ms-1">
                            <form asp-controller="Culture" asp-action="Set" method="post">
                                <input type="hidden" name="culture" value="en" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm px-1 py-0 border-0 bg-transparent" title="English"><span class="fi fi-gb fis" style="font-size:1.4rem; border-radius:3px; display:inline-block;"></span></button>
                            </form>
                            <form asp-controller="Culture" asp-action="Set" method="post">
                                <input type="hidden" name="culture" value="hy" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm px-1 py-0 border-0 bg-transparent" title="Հայերեն"><span class="fi fi-am fis" style="font-size:1.4rem; border-radius:3px; display:inline-block;"></span></button>
                            </form>
                            <form asp-controller="Culture" asp-action="Set" method="post">
                                <input type="hidden" name="culture" value="ru" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm px-1 py-0 border-0 bg-transparent" title="Русский"><span class="fi fi-ru fis" style="font-size:1.4rem; border-radius:3px; display:inline-block;"></span></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="container mt-2">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="container py-3 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container text-center">
            <p class="mb-0">@L["Footer_Copy"]</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Update cart badge from server
        function refreshCartBadge() {
            fetch('/Cart/Count')
                .then(r => r.json())
                .then(d => {
                    document.getElementById('cart-count').textContent = d.count;
                });
        }
        refreshCartBadge();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
