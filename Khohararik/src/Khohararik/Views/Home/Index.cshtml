@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="py-5 text-center" style="background: linear-gradient(135deg, #2d6a4f 0%, #52b788 100%); border-radius: 16px; color: #fff; margin-bottom: 3rem;">
    <div class="py-3">
        <h1 class="display-4 fw-bold mb-3">🥘 Khohararik</h1>
        <p class="lead mb-4">@L["Home_Hero_Sub"]</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Ingredients" asp-action="Index" class="btn btn-light btn-lg fw-semibold px-5">
                <i class="bi bi-grid me-2"></i>@L["Home_Browse"]
            </a>
            <a asp-controller="Recipes" asp-action="Recommendations" class="btn btn-warning btn-lg fw-semibold px-5">
                <i class="bi bi-stars me-2"></i>@L["Nav_GetRecommendations"]
            </a>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="mb-5">
    <h2 class="text-center fw-bold mb-4">@L["Home_HowItWorks"]</h2>
    <div class="row g-4">
        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="display-3 mb-3">🛒</div>
                <h5 class="fw-bold">@L["Home_Step1_Title"]</h5>
                <p class="text-muted">@L["Home_Step1_Desc"]</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="display-3 mb-3">🔍</div>
                <h5 class="fw-bold">@L["Home_Step2_Title"]</h5>
                <p class="text-muted">@L["Home_Step2_Desc"]</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="display-3 mb-3">🍽️</div>
                <h5 class="fw-bold">@L["Home_Step3_Title"]</h5>
                <p class="text-muted">@L["Home_Step3_Desc"]</p>
            </div>
        </div>
    </div>
</section>

