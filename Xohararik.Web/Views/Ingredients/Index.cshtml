@model IngredientsPageViewModel
@{
    ViewData["Title"] = "Ingredients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-grid me-2 text-warning"></i>Ingredients</h2>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-basket2 me-1"></i>View Cart
    </a>
</div>

<!-- Search & Filter Bar -->
<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="search" value="@Model.SearchQuery" class="form-control"
               placeholder="Search ingredients..." />
    </div>
    <div class="col-md-4">
        <select name="category" class="form-select" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat" selected="@(Model.SelectedCategory == cat)">@cat</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-warning w-100">
            <i class="bi bi-search me-1"></i>Search
        </button>
    </div>
</form>

<!-- Category Pills -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm @(Model.SelectedCategory == null ? "btn-dark" : "btn-outline-dark")">All</a>
    @foreach (var cat in Model.Categories)
    {
        <a asp-action="Index" asp-route-category="@cat"
           class="btn btn-sm @(Model.SelectedCategory == cat ? "btn-warning" : "btn-outline-secondary")">
            @cat
        </a>
    }
</div>

<!-- Ingredient Cards -->
@if (!Model.Ingredients.Any())
{
    <div class="alert alert-info">No ingredients found. Try a different search or category.</div>
}
else
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var ingredient in Model.Ingredients)
        {
            <div class="col">
                <div class="card h-100 shadow-sm ingredient-card">
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:140px;">
                        @if (!string.IsNullOrEmpty(ingredient.ImageUrl))
                        {
                            <img src="@ingredient.ImageUrl" alt="@ingredient.Name"
                                 style="max-height:120px; max-width:100%; object-fit:contain;" />
                        }
                        else
                        {
                            <i class="bi bi-egg-fried display-4 text-muted"></i>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary mb-1 align-self-start">@ingredient.CategoryName</span>
                        <h6 class="card-title fw-bold mb-1">@ingredient.Name</h6>
                        <small class="text-muted">
                            <i class="bi bi-lightning me-1"></i>@ingredient.CaloriesPer100g kcal/100g
                        </small>
                        <small class="text-muted">
                            <i class="bi bi-scales me-1"></i>Default: @ingredient.DefaultWeight g
                        </small>
                        <div class="mt-auto pt-2">
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                <input type="hidden" name="ingredientId" value="@ingredient.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                    <i class="bi bi-plus-circle me-1"></i>Add to Cart
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
