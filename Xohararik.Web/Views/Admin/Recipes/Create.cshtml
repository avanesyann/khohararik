@model Xohararik.Web.ViewModels.RecipeFormViewModel
@{
    bool isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Recipe" : "Create Recipe";
    string formAction = isEdit ? $"/Admin/Recipes/Edit/{Model.Id}" : "/Admin/Recipes/Create";
}

<h2 class="fw-bold mb-4">
    <i class="bi bi-@(isEdit ? "pencil" : "plus-circle") me-2 text-warning"></i>@ViewData["Title"]
</h2>

<form action="@formAction" method="post" enctype="multipart/form-data">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold">Recipe Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Recipe Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Instructions (one step per line)</label>
                        <textarea asp-for="Instructions" class="form-control" rows="5"
                                  placeholder="1. Step one&#10;2. Step two"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Total Calories</label>
                        <input asp-for="TotalCalories" type="number" step="1" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Image URL (optional)</label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Or Upload Image</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-bold">Ingredients</div>
                <div class="card-body" style="max-height:500px; overflow-y:auto;">
                    @for (int i = 0; i < Model.IngredientRows.Count; i++)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <input type="hidden" name="IngredientRows[@i].IngredientId"
                                   value="@Model.IngredientRows[i].IngredientId" />
                            <input type="hidden" name="IngredientRows[@i].IngredientName"
                                   value="@Model.IngredientRows[i].IngredientName" />
                            <input type="checkbox" name="IngredientRows[@i].IsSelected"
                                   value="true"
                                   class="form-check-input"
                                   @(Model.IngredientRows[i].IsSelected ? "checked" : "") />
                            <label class="flex-grow-1 mb-0">@Model.IngredientRows[i].IngredientName</label>
                            <input type="number" name="IngredientRows[@i].RequiredWeight"
                                   value="@Model.IngredientRows[i].RequiredWeight"
                                   class="form-control form-control-sm" style="width:80px;" min="1" />
                            <small class="text-muted">g</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-warning fw-bold">
            <i class="bi bi-save me-1"></i>@(isEdit ? "Save Changes" : "Create Recipe")
        </button>
        <a href="/Admin/Recipes" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
