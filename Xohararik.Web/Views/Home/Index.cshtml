@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="bi bi-fire display-1 text-warning"></i>
    </div>
    <h1 class="display-4 fw-bold mb-3">Բարի գալուստ Խոհարարիկ</h1>
    <p class="lead text-muted mb-5">
        Select the ingredients you have at home and discover delicious recipes you can make right now.
    </p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a asp-controller="Ingredients" asp-action="Index" class="btn btn-warning btn-lg px-5">
            <i class="bi bi-grid-fill me-2"></i>Browse Ingredients
        </a>
        <a asp-controller="Recipes" asp-action="Recommendations" class="btn btn-outline-dark btn-lg px-5">
            <i class="bi bi-journal-richtext me-2"></i>See Recipes
        </a>
    </div>
</div>

<div class="row g-4 mt-4 text-center">
    <div class="col-md-4">
        <div class="card border-0 bg-light h-100 p-4">
            <i class="bi bi-basket2 display-4 text-warning mb-3"></i>
            <h5 class="fw-bold">1. Pick Ingredients</h5>
            <p class="text-muted">Browse by category and add ingredients you have in your kitchen.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light h-100 p-4">
            <i class="bi bi-cpu display-4 text-warning mb-3"></i>
            <h5 class="fw-bold">2. Get Recommendations</h5>
            <p class="text-muted">Our system matches your ingredients to recipes — fully or partially.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light h-100 p-4">
            <i class="bi bi-book display-4 text-warning mb-3"></i>
            <h5 class="fw-bold">3. Cook & Enjoy</h5>
            <p class="text-muted">Follow step-by-step instructions and see exactly what you're missing.</p>
        </div>
    </div>
</div>
